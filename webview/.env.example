PORT=8787

# Optional base EULA override. By default the server reads the canonical EULA from the project GitHub repo.
# The webview appends public/EULA_NODE_OPERATOR_TERMS.md from the local node operator checkout.
# For private repositories, set EULA_SOURCE_TOKEN server-side only.
EULA_SOURCE_URL=
EULA_SOURCE_TOKEN=

# Docker / Traefik host.
TRAEFIK_ORACLE_HOST=oracle.objectid.io

# Network-specific config for network switching (devnet/testnet/mainnet).
DEVNET_IOTA_RPC_URL=https://api.devnet.iota.cafe
