PORT=8787

# Network-specific config for network switching (devnet/testnet/mainnet).
DEVNET_IOTA_RPC_URL=https://api.devnet.iota.cafe
DEVNET_ORACLE_TASKS_PACKAGE_ID=0x7521e5910c2cec19b8fbe12f8b2827145ed882812ecd3aef33e7ab81c9b0c630
DEVNET_ORACLE_SYSTEM_PACKAGE_ID=0x9d29664cf826bbabf906e87ef4b88b76560286634c44f834c8ad306a8306dea2
DEVNET_ORACLE_STATE_ID=0xec7b66ccf663491e568daa3599ed3771f0886769eb5bf86f1876d91fa4cecfcf

TESTNET_IOTA_RPC_URL=https://api.testnet.iota.cafe
TESTNET_ORACLE_TASKS_PACKAGE_ID=0xca69402ec6deba4e0b100cb8ec489bcbf8a08e121e2ffbe345fe84fd16f1dd94
TESTNET_ORACLE_SYSTEM_PACKAGE_ID=0xf0ce329c6f779d060208e35ab49fe9edea2c4dd263d630f7c47486d685f725ae
