PORT=8787

# Network-specific config for network switching (devnet/testnet/mainnet).
DEVNET_IOTA_RPC_URL=https://api.devnet.iota.cafe
DEVNET_ORACLE_TASKS_PACKAGE_ID=0xYOUR_DEVNET_TASKS_PACKAGE_ID
DEVNET_ORACLE_SYSTEM_PACKAGE_ID=0xYOUR_DEVNET_SYSTEM_PACKAGE_ID
DEVNET_ORACLE_STATE_ID=0xYOUR_DEVNET_STATE_ID

TESTNET_IOTA_RPC_URL=https://api.testnet.iota.cafe
TESTNET_ORACLE_TASKS_PACKAGE_ID=0xYOUR_TESTNET_TASKS_PACKAGE_ID
TESTNET_ORACLE_SYSTEM_PACKAGE_ID=0xYOUR_TESTNET_SYSTEM_PACKAGE_ID
TESTNET_ORACLE_STATE_ID=0xYOUR_TESTNET_STATE_ID

MAINNET_IOTA_RPC_URL=https://api.mainnet.iota.cafe
MAINNET_ORACLE_TASKS_PACKAGE_ID=0xYOUR_MAINNET_TASKS_PACKAGE_ID
MAINNET_ORACLE_SYSTEM_PACKAGE_ID=0xYOUR_MAINNET_SYSTEM_PACKAGE_ID
MAINNET_ORACLE_STATE_ID=0xYOUR_MAINNET_STATE_ID

# Shared modules and dashboard behavior.
ORACLE_TASK_MODULE=oracle_tasks
ORACLE_MESSAGE_MODULE=oracle_messages
ACTIVE_WINDOW_MINUTES=15
EVENT_FETCH_LIMIT=100
ORACLE_CLIENT_DIR=../iota_oracle_client
ORACLE_CLIENT_EXAMPLES_DIR=examples

# Frontend runtime flags.
VITE_API_BASE_URL=http://localhost:8787
VITE_DEFAULT_NETWORK=mainnet
VITE_SUPPORTED_NETWORKS=mainnet,testnet,devnet
VITE_NETWORK_SWITCH_ENABLED=true
