PORT=8787

# Docker / Traefik host.
TRAEFIK_ORACLE_HOST=oracle.objectid.io

# Network-specific config for network switching (devnet/testnet/mainnet).
DEVNET_IOTA_RPC_URL=https://api.devnet.iota.cafe
DEVNET_ORACLE_TASKS_PACKAGE_ID=0xc77781425814e7dfed1146be51b37508d0a503a2abbbb755592478e42c80af94
DEVNET_ORACLE_SYSTEM_PACKAGE_ID=0xfaec1db0d81afa27354a41aaf5ab0808836d33efca4ed62c40cdebd66e9b55b8
DEVNET_ORACLE_STATE_ID=0xe7cbdf63cf59091ec014bae1898c2e151ba8093c9765b648b251cffcebdaf15f
DEVNET_ORACLE_TREASURY_ID=0x4116d12039552dea295f5dec46c5115254ca9e4c78f437e58097cd0de66f5856

TESTNET_IOTA_RPC_URL=https://api.testnet.iota.cafe
TESTNET_ORACLE_TASKS_PACKAGE_ID=0xa8431312912d3c169cc3d1e7f94dba9a55f529243272cc4e9ef488dce895a8a2
TESTNET_ORACLE_SYSTEM_PACKAGE_ID=0xb275ae736fb18b04a2885f35fb7afbd9857e71ca299e271c3c6304b9ac28448a
TESTNET_ORACLE_STATE_ID=0xd045a6c51614cb55fba9841e7a8b0da62496b41f79b05eeb023ceeea68f8f4b5
TESTNET_ORACLE_TREASURY_ID=0x9e17e9f0deb011eaf4d3745644e13548ced397c0b0a5d666232ba4bed96232d1

MAINNET_IOTA_RPC_URL=https://api.mainnet.iota.cafe
MAINNET_ORACLE_TASKS_PACKAGE_ID=
MAINNET_ORACLE_SYSTEM_PACKAGE_ID=
MAINNET_ORACLE_STATE_ID=
MAINNET_ORACLE_TREASURY_ID=0xYOUR_MAINNET_TREASURY_ID

# Shared modules and dashboard behavior.
ORACLE_TASK_MODULE=oracle_tasks
ORACLE_MESSAGE_MODULE=oracle_messages
ACTIVE_WINDOW_MINUTES=15
EVENT_FETCH_LIMIT=100
ORACLE_CLIENT_DIR=../iota_oracle_client
ORACLE_CLIENT_EXAMPLES_DIR=examples

# Frontend runtime flags.
# Leave empty when the frontend is served by the same host as the API.
# Use http://localhost:8787 only for local development.
VITE_API_BASE_URL=
VITE_DEFAULT_NETWORK=mainnet
VITE_SUPPORTED_NETWORKS=mainnet,testnet,devnet
VITE_NETWORK_SWITCH_ENABLED=true
VITE_HOSTING_TEXT=Proudly hosted by ObjectID

# IOTA.org-inspired theme
VITE_THEME_PAGE_BG="#e3eaf6"
VITE_THEME_TEXT="#171d26"
VITE_THEME_MUTED_TEXT="#717a8a"
VITE_THEME_ACCENT_TEXT="#2563f5"
VITE_THEME_CARD_BG="#ffffff"
VITE_THEME_CARD_BORDER="rgba(192, 203, 217, 0.9)"
VITE_THEME_INPUT_BG="#ffffff"
VITE_THEME_INPUT_BORDER="rgba(192, 203, 217, 0.95)"
VITE_THEME_PRIMARY_BG="#2563f5"
VITE_THEME_PRIMARY_TEXT="#ffffff"
